{
  "name": "@kuafu/framework",
  "version": "1.2.0",
  "description": "Channel-agnostic Agent Runtime Framework",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./kernel": {
      "types": "./dist/kernel.d.ts",
      "import": "./dist/kernel.js"
    },
    "./action": {
      "types": "./dist/action.d.ts",
      "import": "./dist/action.js"
    },
    "./store": {
      "types": "./dist/store.d.ts",
      "import": "./dist/store.js"
    },
    "./telemetry": {
      "types": "./dist/telemetry.d.ts",
      "import": "./dist/telemetry.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/DoSomeForFun/kuafu.git"
  },
  "keywords": [
    "agent",
    "ai",
    "runtime",
    "framework",
    "llm"
  ],
  "author": "Leetao <leetao@duck.com>",
  "license": "MIT",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "node --test tests/*.test.js"
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.11.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.3"
  },
  "files": [
    "dist/",
    "src/"
  ],
  "engines": {
    "node": ">=20"
  }
}
